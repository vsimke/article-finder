{
    "name": "vsimke/article-finder",
    "description": "Framework-agnostic PHP package for finding articles via Bing and Google SERP scraping using a chain-of-responsibility finder pattern.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Vladimir Simic",
            "email": "vladimir.simic@prodevcon.ch"
        }
    ],
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7.0",
        "duzun/hquery": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Vsimke\\ArticleFinder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vsimke\\ArticleFinder\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse",
        "refactor": "vendor/bin/rector",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "stable"
}